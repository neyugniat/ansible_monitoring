global:
  scrape_interval: 15s

alerting:
  alertmanagers:
    - static_configs:
      - targets:
        - "localhost:{{ alertmanager_port }}"

rule_files:
  - alert_rules.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - "localhost:{{ prometheus_port }}"

  - job_name: alertmanager
    static_configs:
      - targets:
          - "localhost:{{ alertmanager_port }}"        

  - job_name: cadvisor
    static_configs:
      - targets:
        {% for host in groups.get('nodes', []) if host %}
          - "{{ hostvars[host].ansible_host }}:{{ cadvisor_port }}"
        {% endfor %}


  - job_name: node_exporter
    static_configs:
      - targets:
        {% for host in groups.get('nodes', []) if host %}
          - "{{ hostvars[host].ansible_host }}:{{ node_exporter_port }}"
        {% endfor %}
groups:
  - name: node-health
    rules:
      {# - alert: TestAlert
        expr: vector(1)
        for: 30s

        labels:
          severity: info

        annotations:
          summary: "Testing Alertmanager"
          description: "This alert should always fire" #}

      - alert: InstanceDown
        expr: up{job="node_exporter"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "{{ '{{' }} $labels.instance {{ '}}' }} is down"
          description: "{{ '{{' }} $labels.instance {{ '}}' }} has been unreachable for 1+ minutes."

      - alert: HighCPU
        expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 85
        for: 2m
        labels:
          severity: warning
        annotations:
          summary: "{{ '{{' }} $labels.instance {{ '}}' }} CPU at {{ '{{' }} $value | humanize {{ '}}' }}"

      - alert: DiskWillFillIn4Hours
        expr: predict_linear(node_filesystem_avail_bytes{fstype!~"tmpfs|overlay"}[6h], 4*3600) < 0
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "{{ '{{' }} $labels.instance {{ '}}' }} disk {{ '{{' }} $labels.mountpoint {{ '}}' }} will fill within 4 hours"

      - alert: HighMemoryUsage
        expr: (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100 > 90
        for: 2m
        labels:
          severity: warning
        annotations:
          summary: "High memory usage on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "Memory usage is {{ '{{' }} printf \"%.2f\" $value {{ '}}' }}%."

      - alert: DiskUsageHigh
        expr: (1 - node_filesystem_avail_bytes{fstype!~"tmpfs|overlay"} / node_filesystem_size_bytes{fstype!~"tmpfs|overlay"}) * 100 > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Disk usage high on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: "{{ '{{' }} $labels.mountpoint {{ '}}' }} is {{ '{{' }} printf \"%.2f\" $value {{ '}}' }}% full."
  
  - name: meta-monitoring
    rules:
      - alert: AlertmanagerDown
        expr: up{job="alertmanager"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Alertmanager is down"